# Copy this file to `.env` in THIS folder (backend/.env), then fill in values.
# Restart uvicorn after any change.

# Google AI Studio: https://aistudio.google.com/apikey
# Put the key on ONE line after = (no quotes). Name must be GEMINI_API_KEY exactly.
GEMINI_API_KEY=AIzaSyBvYio0XgeFXFavODk9o4WEeTe78QdfbMY

JWT_SECRET=change-this-to-a-long-random-string-in-production
DATABASE_URL=sqlite:///./gym_guide.db
# For PostgreSQL later: postgresql+psycopg2://user:pass@host:5432/gym_guide
GOOGLE_CLIENT_ID=
# Optional: restrict uploads size (bytes)
MAX_UPLOAD_BYTES=5242880

# AI: set true in production to enforce AI_DAILY_LIMIT and track calls (default off for testing)
# AI_RATE_LIMIT_ENABLED=false
# AI_DAILY_LIMIT=10
